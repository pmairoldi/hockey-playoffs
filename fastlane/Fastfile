fastlane_version '2.88.0'

default_platform :ios

platform :ios do
  before_all do
    clean_build_artifacts
  end

  desc 'Runs all the tests'
  lane :test do
    scan(
      workspace: 'HockeyPlayoffs.xcworkspace',
      scheme: 'HockeyPlayoffsTests',
      device: 'iPhone 17 Pro (26.4)',
    )
  end

  desc 'Builds app and packages it'
  private_lane :build do |options|
    snapshot if options[:screenshots]

    create_keychain(
      name: "CI_Keychain",
      password: ENV["KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    match(
      type: "appstore", 
      keychain_name: "CI_Keychain",
      keychain_password: ENV["KEYCHAIN_PASSWORD"],  
      readonly: true
    )

    gym( workspace: 'HockeyPlayoffs.xcworkspace', scheme: 'HockeyPlayoffs')

    if options[:beta]
      deliver(force: true, submit_for_review: false)
    else
      deliver(force: true, submit_for_review: true)
    end

    clean_build_artifacts
  end

  desc 'Submit a new Beta Build to Apple TestFlight'
  lane :beta do |options|
    increment_build_number
    build(beta: true, screenshots: options[:screenshots])
  end

  desc 'Deploy a new version to the App Store'
  lane :deploy do |options|
    build(screenshots: options[:screenshots])
  end

  after_all do
    delete_keychain(name: "CI_Keychain") if File.exist?(File.expand_path("~/Library/Keychains/CI_Keychain-db"))
  end
end
